generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                  @id @default(cuid())
  username                String                  @unique
  email                   String                  @unique
  password                String
  avatar                  String?
  fullName                String?
  language                String                  @default("en")
  timezone                String                  @default("America/New_York")
  country                 String                  @default("US")
  emailPrivateMessages    Boolean                 @default(true)
  emailMatchNotifications Boolean                 @default(true)
  markReadOnEmail         Boolean                 @default(true)
  productUpdates          Boolean                 @default(false)
  optOutPersonalizedAds   Boolean                 @default(false)
  subscriptionPlan        String                  @default("free")
  stripeCustomerId        String?                 @unique
  stripeSubscriptionId    String?                 @unique
  subscriptionStatus      String?
  billingInterval         String?
  currentPeriodEnd        DateTime?
  role                    String                  @default("player")
  rankPoints              Int                     @default(0)
  wins                    Int                     @default(0)
  losses                  Int                     @default(0)
  tournaments             TournamentParticipant[]
  matches1                Match[]                 @relation("player1Matches")
  matches2                Match[]                 @relation("player2Matches")
  winsAsWinner            Match[]                 @relation("winnerMatches")
  passwordResetTokens     PasswordResetToken[]
  clubRequests            ClubRequest[]
  organizerRequests       OrganizerRequest[]
  contactMessages         ContactMessage[]
  blockedUsers            BlockedUser[]           @relation("UserBlocks")
  conversationsAsLow      Conversation[]          @relation("ConversationLow")
  conversationsAsHigh     Conversation[]          @relation("ConversationHigh")
  sentDirectMessages      DirectMessage[]
  directMessageLikes      DirectMessageLike[]
  directMessageHides      DirectMessageHide[]
  conversationUserStates  ConversationUserState[]
  hostedTournaments       Tournament[]            @relation("TournamentCreator")
  hostedEvents            Event[]                 @relation("EventHost")
  tournamentTemplates     TournamentTemplate[]
  createdAt               DateTime                @default(now())

  @@index([role, rankPoints(sort: Desc), wins(sort: Desc)])
}

model BlockedUser {
  id         String   @id @default(cuid())
  user       User     @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  identifier String
  createdAt  DateTime @default(now())

  @@unique([userId, identifier])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Conversation {
  id                String          @id @default(cuid())
  participantLow    User            @relation("ConversationLow", fields: [participantLowId], references: [id], onDelete: Cascade)
  participantLowId  String
  participantHigh   User            @relation("ConversationHigh", fields: [participantHighId], references: [id], onDelete: Cascade)
  participantHighId String
  messages          DirectMessage[]
  userStates        ConversationUserState[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([participantLowId, participantHighId])
  @@index([participantLowId, updatedAt(sort: Desc)])
  @@index([participantHighId, updatedAt(sort: Desc)])
}

model DirectMessage {
  id             String              @id @default(cuid())
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  body           String              @default("")
  imageUrl       String?
  editedAt       DateTime?
  unsentAt       DateTime?
  readAt         DateTime?
  createdAt      DateTime            @default(now())
  likes          DirectMessageLike[]
  hiddenFor      DirectMessageHide[]

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([senderId])
}

model DirectMessageLike {
  id        String        @id @default(cuid())
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model DirectMessageHide {
  id        String        @id @default(cuid())
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  messageId String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([messageId, userId])
  @@index([userId])
}

model ConversationUserState {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([conversationId, userId])
  @@index([userId, archivedAt])
  @@index([userId, deletedAt])
}

model CommunityClub {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  tagline     String?
  region      String
  captain     String?
  memberCount Int      @default(0)
  eventsCount Int      @default(0)
  verified    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([region])
}

model ClubRequest {
  id           String   @id @default(cuid())
  clubName     String
  region       String
  captain      String?
  contactName  String?
  contactEmail String
  memberCount  Int?
  message      String?
  status       String   @default("pending")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId       String?
  createdAt    DateTime @default(now())

  @@index([status, createdAt(sort: Desc)])
}

model OrganizerRequest {
  id        String   @id @default(cuid())
  message   String
  status    String   @default("pending")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@index([status, createdAt(sort: Desc)])
  @@index([userId, status])
}

model ContactMessage {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String
  message    String
  category   String    @default("general")
  status     String    @default("pending")
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
}

model Event {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String?
  description      String?
  startsAt         DateTime
  endsAt           DateTime?
  timezone         String   @default("America/New_York")
  venueName        String?
  location         String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  country          String?
  isOnline         Boolean  @default(false)
  status           String   @default("draft")
  host             User     @relation("EventHost", fields: [hostId], references: [id], onDelete: Cascade)
  hostId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([hostId])
  @@index([slug])
}

model Tournament {
  id                  String                  @id @default(cuid())
  slug                String?                 @unique
  name                String
  description         String?
  date                DateTime
  checkInTime         String?
  eventStartTime      String?
  location            String?
  format              String                  @default("single_elimination")
  status              String                  @default("open")
  groupStageEnabled   Boolean                 @default(false)
  groupSize           Int                     @default(4)
  advancePerGroup     Int                     @default(2)
  grandFinalsModifier String                  @default("default")
  deSplitLosersBracket Boolean                @default(true)
  deBreakTiesPlacement Boolean                @default(true)
  phase               String?
  entryFee            String?
  prizePool           String?
  playerCap           Int?
  isRanked            Boolean                 @default(true)
  gameType            String                  @default("beyblade_x")
  swissPointsPerMatchWin Float                @default(1)
  swissPointsPerMatchTie Float                @default(0.5)
  swissPointsPerGameWin  Float                @default(0)
  swissPointsPerGameTie  Float                @default(0)
  swissPointsPerBye      Float                @default(1)
  roundRobinRankBy       String               @default("match_wins")
  createdBy           User?                   @relation("TournamentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdById         String?
  participants        TournamentParticipant[]
  matches             Match[]
  createdAt           DateTime                @default(now())

  @@index([createdById])
}

model TournamentTemplate {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  format              String   @default("single_elimination")
  groupStageEnabled   Boolean  @default(false)
  groupSize           Int      @default(4)
  advancePerGroup     Int      @default(2)
  grandFinalsModifier String   @default("default")
  deSplitLosersBracket Boolean @default(true)
  deBreakTiesPlacement Boolean @default(true)
  entryFee            String?
  prizePool           String?
  playerCap           Int?
  isRanked            Boolean  @default(true)
  gameType            String   @default("beyblade_x")
  swissPointsPerMatchWin Float @default(1)
  swissPointsPerMatchTie Float @default(0.5)
  swissPointsPerGameWin  Float @default(0)
  swissPointsPerGameTie  Float @default(0)
  swissPointsPerBye      Float @default(1)
  roundRobinRankBy       String @default("match_wins")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  walkInName   String?
  seed         Int?
  groupId      Int?
  placement    Int?
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
}

model Match {
  id             String     @id @default(cuid())
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId   String
  player1        User?      @relation("player1Matches", fields: [player1Id], references: [id])
  player1Id      String?
  player2        User?      @relation("player2Matches", fields: [player2Id], references: [id])
  player2Id      String?
  winner         User?      @relation("winnerMatches", fields: [winnerId], references: [id])
  winnerId       String?
  score          String?
  round          Int        @default(1)
  matchIndex     Int        @default(0)
  bracketSide    String     @default("winners")
  groupId        Int?
  winnerNextId   String?
  winnerNextSlot Int?
  loserNextId    String?
  loserNextSlot  Int?
  status         String     @default("pending")
  createdAt      DateTime   @default(now())

  @@index([tournamentId, bracketSide, round, matchIndex])
}
